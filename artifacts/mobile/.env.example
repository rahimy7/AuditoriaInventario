# API endpoint for the mobile app
# For local development on a physical device, use your machine's LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.64:5055/api
#
# For simulator/emulator on the same machine:
# EXPO_PUBLIC_API_URL=http://localhost:5055/api
#
# For production (Railway):
# EXPO_PUBLIC_API_URL=https://<your-app>.up.railway.app/api
EXPO_PUBLIC_API_URL=http://localhost:5055/api
